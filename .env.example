# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# WordPress Site (add one block per site)
WP_SITE_URL=https://yoursite.com
WP_USERNAME=your_wp_username
WP_APP_PASSWORD=your_wp_application_password

# Google Search Console (path to OAuth2 credentials JSON downloaded from Google Cloud Console)
GOOGLE_CREDENTIALS_FILE=credentials.json

# Email outreach (for backlink outreach)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# SerpAPI (optional - for finding backlink opportunities)
SERP_API_KEY=your_serpapi_key_here
